<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <!--
            Notification Click Receiver — fires when user taps a SDK-displayed
            notification. Registered via SDK's own PendingIntent, no conflict
            with client's own notification handling.
        -->
        <receiver
            android:name="com.thoughtnudge.sdk.TNNotificationClickReceiver"
            android:exported="false" />

        <!--
            Notification Dismiss Receiver — fires when user swipes away a
            SDK-displayed notification.
        -->
        <receiver
            android:name="com.thoughtnudge.sdk.TNNotificationDismissReceiver"
            android:exported="false" />
    </application>

</manifest>
